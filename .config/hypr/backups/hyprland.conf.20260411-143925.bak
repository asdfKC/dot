################
### MONITORS ###
################

monitor = DP-1, 2560x1440@165, 0x0, 1
monitor = eDP-1, 1366x768@144, 2560x0, 1


################
### PROGRAMS ###
################

$terminal = kitty
$fileManager = dolphin
$menu = wofi --show drun


#################
### AUTOSTART ###
#################

exec-once = waybar
exec-once = hyprpaper
exec-once = hyprlock
exec-once = hypridle
exec-once = swaync


###################
### LOOK & FEEL ###
###################

general {
    gaps_in = 8
    gaps_out = 16
    border_size = 2

    col.active_border = 0xffd4af37
    col.inactive_border = 0xff282828

    layout = dwindle
}

decoration {
    rounding = 10

    shadow {
        enabled = true
        range = 6
        color = rgba(0, 0, 0, 0.6)
    }

    blur {
        enabled = true
        size = 6
        passes = 2
    }
}

animations {
    enabled = yes
}


#############
### INPUT ###
#############

input {
    kb_layout = us
    follow_mouse = 1
}


###################
### KEYBINDINGS ###
###################

$mainMod = SUPER

bind = $mainMod, RETURN, exec, $terminal
bind = $mainMod, Q, killactive
bind = $mainMod, E, exec, $fileManager
bind = $mainMod, V, togglefloating
bind = $mainMod, W, exec, google-chrome-stable
bind = $mainMod, L, exec, hyprlock

bind = SUPER, R, exec, pkill waybar && waybar
bindr = $mainMod, SUPER_L, exec, $menu

bind = $mainMod, B, exec, blueman-manager

bindel = , XF86AudioRaiseVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%+
bindel = , XF86AudioLowerVolume, exec, wpctl set-volume @DEFAULT_AUDIO_SINK@ 5%-
bindel = , XF86AudioMute, exec, wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle

bindel = , XF86MonBrightnessUp, exec, brightnessctl set 2%+
bindel = , XF86MonBrightnessDown, exec, brightnessctl set 2%-
